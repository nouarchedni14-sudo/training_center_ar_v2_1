# ============================================================
# Training Center - خادم مكتب محلي مستقل مع مزامنة
# انسخه إلى: C:\TrainingCenterData\.env أو C:\TrainingCenterData_Test2\.env
# ============================================================

DJANGO_ENV=lan
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-office

DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,192.168.1.46,ALI
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://192.168.1.46:8000,http://ALI:8000

APP_DATA_DIR=C:/TrainingCenterData
DB_ENGINE=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=training_center
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_CONN_MAX_AGE=120

LAN_SERVER_HOST=0.0.0.0
LAN_SERVER_PORT=8000
LAN_SERVER_PUBLIC_BASE_URL=http://127.0.0.1:8000
LAN_HEALTH_TOKEN=

SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0
# عند نشر المكتب أو المركز خلف HTTPS/Reverse Proxy اجعلها 1.
BEHIND_REVERSE_PROXY=0
WAITRESS_THREADS=8
WAITRESS_CONNECTION_LIMIT=100
WAITRESS_CHANNEL_TIMEOUT=120
DJANGO_LOG_LEVEL=INFO
# يطبق البرنامج migrate + check تلقائيًا عند تشغيل المكتب.
RUN_STARTUP_TASKS=1


# هوية المؤسسة/المكتب المحلي الرسمية
# الصيغة الرسمية: OFFICE_CODE = الدولة + الولاية + البلدية + نوع المؤسسة + رقم المؤسسة
# مثال: DZ38-03801-INSFP01
SYNC_MODE=local_office
WILAYA_CODE=38
COMMUNE_CODE=03801
OFFICE_CODE=DZ38-03801-INSFP01
OFFICE_ALIAS=DZ38-TIS-INSFP01
OFFICE_NAME=Tissemsilt_INSFP01
OFFICE_DISPLAY_NAME=المعهد الوطني المتخصص في التكوين المهني الشهيد تاج الدين حامد عبد الوهاب - تيسمسيلت
INSTITUTION_TYPE=INSFP
INSTITUTION_SERIAL=01
# في التثبيت الآمن لا نضع OFFICE_ID ولا SYNC_TOKEN قبل موافقة المطوّر.
# الجهاز يطلب الربط أولًا، ثم يمنحه المطوّر المكتب والرمز من اللوحة المركزية.
OFFICE_ID=
# SERVER_ID يجب أن يكون مختلفًا في كل جهاز؛ اتركه auto وسيتم توليده عند أول تشغيل.
SERVER_ID=auto
DEVICE_NODE_MODE=1
DEVICE_NODE_INITIALIZED=0
CENTRAL_URL=
# إذا كان المكتب خارج المؤسسة، ضع رابط HTTPS العام للخادم المركزي مثل:
# CENTRAL_URL=https://updates.example.com

# يتم ضبطها تلقائيًا من صفحة إضافة مكتب أو من REBUILD_FROM_ZERO_FINAL.ps1
CENTRAL_SYNC_ENABLED=0
SYNC_WORKER_ENABLED=0
# عامل مزامنة داخلي يعمل داخل TrainingCenterOfficeServer.exe؛ لا يحتاج Python منفصل.
IN_PROCESS_SYNC_WORKER_ENABLED=1
SYNC_WORKER_INTERVAL_SECONDS=120
SYNC_TOKEN=
DEVICE_REQUEST_SECRET=

SYNC_TRACKING_ENABLED=0
SYNC_AUDIT_OUTBOX_ENABLED=1
OFFICE_PULL_TOKEN=
SYNC_TRACKED_MODELS=trainees.حضوري_أولي,trainees.تمهين,trainees.دفعة,trainees.مسائي_ومعابر
SYNC_BATCH_SIZE=100
SYNC_PULL_LIMIT=100
SYNC_CONFLICT_POLICY=last_write_wins
SYNC_APPLY_INBOX_ENABLED=1
SYNC_APPLY_LIMIT=100

APP_VERSION=1.0.0
# فعّلها إلى 1 عندما يكون CENTRAL_URL مضبوطًا، سواء داخل الشبكة أو عبر الإنترنت.
ALLOW_REMOTE_UPDATES=0
UPDATE_SERVER_URL=
CENTRAL_DEFAULT_UPDATE_CHANNEL=stable
CENTRAL_TRAINEE_MANAGER_URL=http://127.0.0.1:8000/developer/login/

CENTRAL_DASHBOARD_URL=http://127.0.0.1:9000/central/

# إذا كان PostgreSQL مثبتًا مسبقًا وكلمة مروره منسية، يمكن للمثبت إنشاء PostgreSQL خاص بالبرنامج على منفذ بديل.
# المنفذ البديل الافتراضي أثناء بناء المثبت: 5433

# حساب المطوّر لا يُنشأ ولا يُحفظ في أجهزة الموظفين
DEV_LOGIN_ENABLED=0
# فتح المتصفح تلقائيًا عند تشغيل البرنامج على الجهاز المحلي
AUTO_OPEN_BROWSER=1
PREFER_CHROME_BROWSER=1
# يملأه البرنامج تلقائيًا إذا وجد Google Chrome على الجهاز.
CHROME_EXE_PATH=
AUTO_OPEN_BROWSER_DELAY_SECONDS=2
AUTO_OPEN_BROWSER_TIMEOUT_SECONDS=45


# ============================================================
# Training Center - الخادم المركزي للمطور والمزامنة
# انسخ هذا الملف إلى: C:\TrainingCenterCentralData\.env
# ============================================================

DJANGO_ENV=central
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-central

DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:9000,http://localhost:9000
# إذا نشرت الخادم على الإنترنت أضف النطاق هنا، مثال:
# DJANGO_ALLOWED_HOSTS=updates.example.com,127.0.0.1,localhost
# DJANGO_CSRF_TRUSTED_ORIGINS=https://updates.example.com,http://127.0.0.1:9000,http://localhost:9000
CENTRAL_ALLOW_ALL_HOSTS=0
# الرابط العام الذي ستستعمله المكاتب الخارجية. داخل LAN يمكن تركه فارغًا أو وضع http://ADEM:9000
CENTRAL_PUBLIC_URL=

APP_DATA_DIR=C:/TrainingCenterCentralData
DB_ENGINE=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=training_center_central
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_CONN_MAX_AGE=120

SYNC_MODE=central_server
CENTRAL_SYNC_API_ENABLED=1
CENTRAL_AUTO_REGISTER_OFFICES=0
SYNC_PULL_LIMIT=100

# المدير الأعلى الرئيسي
DEV_USERNAME=
DEV_PASSWORD=
DEV_EMAIL=

# زر برنامج تسيير المتكونين داخل لوحة المطور المركزية
CENTRAL_TRAINEE_MANAGER_URL=http://127.0.0.1:8000/developer/login/

# فتح لوحة المطور المركزية تلقائيًا في Google Chrome عند توفره
AUTO_OPEN_BROWSER=1
PREFER_CHROME_BROWSER=1
AUTO_OPEN_BROWSER_URL=http://127.0.0.1:9000/
# يملأه setup_central_server.bat تلقائيًا إذا وجد Chrome
CHROME_EXE_PATH=

# بيانات الولايات والبلديات تستورد تلقائيًا من sync_core/data/algeria_cities.csv بعد migrate.
# عند إنشاء مؤسسة جديدة استعمل الصيغة:
# OFFICE_CODE=DZ38-03801-INSFP01
# OFFICE_ID=office_dz38_03801_insfp01

# التحكم المركزي والتراخيص
CENTRAL_CONTROL_ENABLED=1
CENTRAL_DEFAULT_LICENSE_PLAN=standard
CENTRAL_DEFAULT_MAX_USERS=5
CENTRAL_DEFAULT_FEATURE_FLAGS={"trainees_add":true,"trainees_edit":true,"trainees_delete":false,"reports_export":true,"attendance":true,"media_upload":true,"admin_panel":false}

# التحديثات المركزية
APP_VERSION=1.0.0
CENTRAL_DEFAULT_UPDATE_CHANNEL=stable
CENTRAL_LATEST_VERSION=1.0.0
CENTRAL_UPDATE_DOWNLOAD_URL=
CENTRAL_UPDATE_NOTES=

# عند HTTPS اجعل COOKIE_SECURE=1 و BEHIND_REVERSE_PROXY=1
SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0
BEHIND_REVERSE_PROXY=0
DJANGO_LOG_LEVEL=INFO
# ملفات التشغيل تطبق migrate + check تلقائيًا على الخادم المركزي.
CENTRAL_AUTO_MAINTENANCE=1

# فعّل هذا فقط في جهاز المطوّر/الخادم المركزي بعد ملء بيانات المطوّر في ملف .env الحقيقي
DEV_LOGIN_ENABLED=1
